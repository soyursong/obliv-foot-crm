{
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "redirects": [
    {
      "source": "/checkin/jongno-foot",
      "destination": "https://foot-checkin.pages.dev/jongno-foot",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
