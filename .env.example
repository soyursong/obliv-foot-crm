# 풋센터 CRM 환경변수 템플릿
# .env.local 에 복사 후 실제 값으로 채워서 사용
# ⚠️  이 파일을 커밋하지 마세요 (.env.local 은 .gitignore 처리됨)

# Supabase 연결 (필수)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# 개발용 — 로컬에서 인증 잠금 해제 (운영 배포 시 제거)
# VITE_DISABLE_AUTH_LOCK=1

# 외국인 셀프접수 국내체류지(숙소) 검색 — 카카오 로컬 API REST 키 (무료 티어, 선택)
#   미설정 시 숙소검색 위젯은 자동으로 수기 주소입력 모드로 fallback.
#   ⚠ 프론트 노출 키 → 카카오 개발자콘솔에서 사용 도메인 제한 필수.
# VITE_KAKAO_REST_API_KEY=<kakao-rest-api-key>

# ─────────────────────────────────────────────────────────────────────────────
# E2E / QA 로컬 실행 가이드 (Playwright)
# ─────────────────────────────────────────────────────────────────────────────
# playwright.config.ts 는 .env → .env.test → .env.local 순으로 로드하여 process.env 에 주입한다.
# 로컬/QA 러너(supervisor 런타임 포함)에서 `npx playwright test` 가 동작하려면
# 아래 값을 .env.local (gitignored) 에 채워야 한다. 누락 시 auth.setup.ts 가
# "VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY 가 .env에 없습니다" 로 즉시 실패한다.
#
#   [필수 — auth.setup 로그인용]
#     VITE_SUPABASE_URL        = https://rxlomoozakkjesdqjtvd.supabase.co
#     VITE_SUPABASE_ANON_KEY   = <anon public key — 프론트 번들 inlining 공개 키>
#
#   [필수 — seed 기반 시나리오 spec(픽스처 생성) + global-setup 픽스처 스윕용]
#     SUPABASE_SERVICE_ROLE_KEY = <service-role-key>   # 없으면 시나리오 spec 이 test.skip 으로 강등됨
#
#   [필수 — 로그인 계정]
#     TEST_USER_EMAIL / TEST_USER_PASSWORD  (CI 관례)  또는  TEST_EMAIL / TEST_PASSWORD (로컬 관례)
#       → auth.setup.ts 가 둘 다 수용
#
# CI(.github/workflows/ci-*.yml)는 위 값을 GitHub Actions Secrets 로 주입한다(이미 구성됨).
# 로컬은 위 키들을 .env.local 에 직접 채운다(절대 커밋 금지).
# SUPABASE_DB_PASSWORD=<db-password>      # DB 정책 spec 일부에서만 사용 (선택)
