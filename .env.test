VITE_DISABLE_AUTH_LOCK=1

# ── Supabase 더미 placeholder (E2E 모듈 로드 가드용) ──────────────────────────
# FIX-REQUEST MSG-20260715-114337-t54c (T-20260714-foot-DOCPRINT-GONGDAN-HIDE-COPAY-ONLY):
#   unit spec 이 src/lib/footBilling → src/lib/supabase 를 import 할 때 모듈 로드 가드
#   (supabase.ts:13, VITE_SUPABASE_URL/ANON_KEY 부재 시 throw)에서 QA 워크트리(.env.local 부재)
#   가 collection 단계에서 통째 실패하던 근인 차단.
#   - supabase.ts 는 Vite 밖(Node) 에서 process.env 로 폴백 → playwright.config 가 .env.test 를 주입.
#   - 순수 함수/page.setContent 렌더 spec 은 네트워크 호출이 없어 값이 가짜여도 안전(접속 시도 없음).
#   - global-setup/teardown 은 VITE_SUPABASE_URL && SUPABASE_SERVICE_ROLE_KEY 동시 필요 →
#     service_role 미주입 시 픽스처 스윕은 그대로 skip(더미 URL 접속 시도 없음).
#   - 실 Supabase 접속이 필요한 spec(desktop-chrome/Management API)은 .env.local(비커밋,
#     dotenv override:true)의 진짜 값이 이 더미를 덮어씀 → 운영/로컬 동작 불변.
VITE_SUPABASE_URL=https://dummy-e2e.local.supabase.co
VITE_SUPABASE_ANON_KEY=dummy-e2e-anon-key-placeholder-not-a-secret
